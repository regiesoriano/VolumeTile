<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />

    <application android:label="@string/app_name">
        <activity
            android:name=".VolumePanelActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:finishOnTaskLaunch="true"
            android:noHistory="true"
            android:theme="@style/Theme.VolumeTile.NoDisplay" />

        <service
            android:name=".VolumePanelForegroundService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback" />

        <service
            android:name=".VolumeTileService"
            android:exported="true"
            android:icon="@drawable/ic_audiotrack_black_24dp"
            android:label="@string/volume_tile_name"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <service
            android:name=".PowerTileService"
            android:exported="true"
            android:icon="@drawable/lock"
            android:label="@string/power_tile_name"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>
    </application>
</manifest>
